#!/usr/bin/env bash
# commit-msg hook: validate the title against Conventional Commits 1.0.0.
# Installed via scripts/install-commit-msg-hook.sh -- see SKILL.md for the
# rest of this workflow.
set -euo pipefail

msg_file="$1"
first_line=$(head -n1 "$msg_file")

# Merge commits and rebase/cherry-pick artifacts aren't hand-written titles;
# don't enforce format on them.
if [[ "$first_line" =~ ^(Merge |Revert |fixup!|squash!|amend!) ]]; then
  exit 0
fi

# Adjust this list if a project genuinely needs more types -- don't add
# ones Conventional Commits merely *permits* without a real need for them.
# `ai` is not a stock Conventional Commits type -- it's reserved for
# commits generated mechanically by this skill's own scripts (currently
# just scripts/drop-specs.sh). Never hand-write an `ai`-type commit.
allowed_types='feat|fix|docs|refactor|test|chore|ai'
pattern="^(${allowed_types})(\([a-zA-Z0-9_/-]+\))?!?: .+"

if ! [[ "$first_line" =~ $pattern ]]; then
  echo "error: commit title doesn't follow Conventional Commits:" >&2
  echo "  \"$first_line\"" >&2
  echo >&2
  echo "expected: <type>[(scope)][!]: <description>" >&2
  echo "type must be one of: ${allowed_types//|/, }" >&2
  echo >&2
  echo "examples:" >&2
  echo "  feat(auth): add JWT-based login" >&2
  echo "  fix!: correct off-by-one in pagination" >&2
  exit 1
fi

exit 0
